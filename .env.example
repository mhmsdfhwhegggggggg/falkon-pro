# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Redis Configuration (Optional - Mock Queue will be used if not provided)
REDIS_URL=redis://default:password@host:6379

# Telegram API Configuration (Get from my.telegram.org)
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash

# Security Keys (Generate new ones for production)
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
SESSION_SECRET=your_session_secret_minimum_32_characters_long
ENCRYPTION_KEY=your_encryption_key_exactly_32_chars

# OAuth Configuration
OAUTH_SERVER_URL=https://your-oauth-server.com
APP_ID=dragon_telegram_pro_mobile
OWNER_OPEN_ID=

# Feature Flags
ENABLE_LICENSE_CHECK=false
ENABLE_REGISTRATION=true
ENABLE_ANALYTICS=true
ANTI_BAN_ENABLED=true

# CORS Configuration
CORS_ORIGINS=*

# Server Configuration
NODE_ENV=development
PORT=3000
EXPO_PORT=8081

# Admin Configuration
ADMIN_EMAIL=admin@falcon.pro
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_NAME=Falcon Admin

# AI Integration (Optional - for AI-powered auto-reply)
AI_API_KEY=your_openai_api_key
AI_BASE_URL=https://api.openai.com/v1

# Public URL (Required for CORS in production)
PUBLIC_URL=https://your-production-domain.com

# Session Encryption Key (auto-generated if not set, but recommended to set explicitly)
SESSION_ENC_KEY=your_session_encryption_key_32_chars

# Integrity Checker (set to 'true' to enforce shutdown on file tampering)
INTEGRITY_ENFORCE_SHUTDOWN=false

# Logging
LOG_LEVEL=info
DEBUG=false
